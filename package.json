{
    "name": "bug-bounty-programs",
    "version": "1.0.0",
    "description": "Bug Bounty Programs Tracker",
    "private": true,
    "dependencies": {
        "node-schedule": "^2.1.1",
        "playwright": "^1.58.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-scripts": "5.0.1"
    },
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "scrape": "node scraper-master.js",
        "scrape:all": "npm run scrape && npm run build",
        "scheduler": "node scraper-scheduler.js",
        "scheduler:run-now": "node scraper-scheduler.js now"
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}